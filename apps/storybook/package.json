{
  "name": "@repo/storybook",
  "version": "0.0.1-alpha.0",
  "private": true,
  "type": "module",
  "description": "Storybook for @beratiyilik react component libraries",
  "author": "Berat Iyilik",
  "license": "LGPL-3.0-or-later",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "storybook:dev": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf storybook-static node_modules .turbo"
  },
  "dependencies": {
    "@beratiyilik/react-components": "workspace:*",
    "@beratiyilik/react-table": "workspace:*"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.2",
    "styled-components": "^6.4.2",
    "typescript": "^6.0.3"
  }
}
