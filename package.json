{
  "name": "react-libs",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "author": "Berat Iyilik",
  "license": "LGPL-3.0-or-later",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "turbo run check:publint check:attw",
    "pre-commit": "bash .husky/pre-commit",
    "clean": "turbo run clean",
    "clean:root": "rm -rf node_modules .turbo pnpm-lock.yaml",
    "clean:all": "pnpm clean && pnpm clean:root",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish",
    "prepare": "husky",
    "storybook:dev": "turbo run storybook:dev",
    "storybook:build": "turbo run storybook:build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
