{
  "name": "@beratiyilik/react-table",
  "version": "0.1.0-alpha.5",
  "description": "React table component built on react-components",
  "keywords": [
    "react",
    "table",
    "components",
    "styled-components",
    "typescript",
    "ui"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "check:publint": "publint",
    "check:attw": "echo 'TODO: attw incompatible with Node 24 (untar.js DecompressionStream bug); fix: attw --pack . && rm *.tgz'",
    "clean": "rm -rf dist node_modules .turbo *.tgz *.tsbuildinfo",
    "prepublishOnly": "pnpm build && pnpm check:publint && pnpm check:attw"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "styled-components": ">=6.0.0"
  },
  "dependencies": {
    "@beratiyilik/react-components": "workspace:*",
    "fuse.js": "^7.4.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beratiyilik/react-libs.git",
    "directory": "packages/react-table"
  },
  "homepage": "https://github.com/beratiyilik/react-libs/tree/main/packages/react-table#readme",
  "bugs": {
    "url": "https://github.com/beratiyilik/react-libs/issues"
  },
  "author": "Berat Iyilik",
  "license": "LGPL-3.0-or-later",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "styled-components": "^6.4.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
